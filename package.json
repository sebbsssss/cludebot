{
  "name": "clude-bot",
  "version": "2.7.8",
  "description": "Persistent memory SDK for AI agents \u2014 Stanford Generative Agents architecture on Supabase + pgvector",
  "main": "dist/sdk/index.js",
  "types": "dist/sdk/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/sdk/index.js",
      "types": "./dist/sdk/index.d.ts"
    },
    "./schema": "./supabase-schema.sql",
    "./local": {
      "require": "./dist/mcp/local-store.js",
      "types": "./dist/mcp/local-store.d.ts"
    },
    "./mcp": {
      "require": "./dist/mcp/server.js",
      "types": "./dist/mcp/server.d.ts"
    }
  },
  "bin": {
    "clude-bot": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "supabase-schema.sql",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:sdk": "tsc -p tsconfig.sdk.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build:sdk",
    "mcp": "MCP_MODE=1 tsx src/mcp/server.ts",
    "dashboard": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build"
  },
  "keywords": [
    "ai-agent",
    "memory",
    "cognitive-architecture",
    "generative-agents",
    "solana",
    "supabase",
    "pgvector",
    "anthropic",
    "claude",
    "embeddings",
    "dream-cycle",
    "sdk",
    "persistent-memory",
    "agent-memory",
    "llm",
    "mcp",
    "long-term-memory",
    "memory-system",
    "vector-search",
    "knowledge-graph",
    "rag",
    "langchain",
    "ai-memory"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebbsssss/cludebot.git"
  },
  "homepage": "https://clude.io",
  "bugs": {
    "url": "https://github.com/sebbsssss/cludebot/issues"
  },
  "author": "sebbsssss",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@solana/web3.js": "^1.98.4",
    "@supabase/supabase-js": "^2.95.3",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "jose": "^6.1.3",
    "node-cron": "^3.0.3",
    "pino": "^9.0.0",
    "tweetnacl": "^1.0.3",
    "twitter-api-v2": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.11",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "optionalDependencies": {
    "utf-8-validate": "^5.0.10"
  }
}