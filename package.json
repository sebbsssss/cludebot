{
  "name": "@clude/sdk",
  "version": "3.0.3",
  "mcpName": "io.github.sebbsssss/clude",
  "description": "Persistent memory SDK for AI agents — Stanford Generative Agents architecture on Supabase + pgvector",
  "main": "dist/sdk/index.js",
  "exports": {
    ".": {
      "require": "./dist/sdk/index.js"
    },
    "./schema": "./supabase-schema.sql",
    "./local": {
      "require": "./dist/mcp/local-store.js"
    },
    "./mcp": {
      "require": "./dist/mcp/server.js"
    }
  },
  "bin": {
    "clude": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "supabase-schema.sql",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:server": "turbo dev --filter=@clude/server",
    "dev:chat": "turbo dev --filter=@clude/chat",
    "dev:dashboard": "turbo dev --filter=@clude/dashboard",
    "dev:workers": "turbo dev --filter=@clude/workers",
    "build": "turbo build",
    "build:clean": "pnpm clean && turbo build",
    "build:publish": "node scripts/build-publish.mjs",
    "clean": "rimraf --glob \"apps/*/dist\" \"packages/*/dist\" \".turbo\" \"apps/*/.turbo\" \"packages/*/.turbo\"",
    "clean:all": "pnpm dlx rimraf --glob \"apps/*/dist\" \"packages/*/dist\" \".turbo\" \"apps/*/.turbo\" \"packages/*/.turbo\" \"node_modules\" \"apps/*/node_modules\" \"packages/*/node_modules\"",
    "start": "pnpm --filter @clude/server start",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:watch": "pnpm --filter @clude/server test:watch",
    "prepublishOnly": "pnpm --filter @clude/shared build && pnpm --filter @clude/brain build && node scripts/build-publish.mjs",
    "dashboard": "cd apps/dashboard && pnpm run dev",
    "dashboard:build": "cd apps/dashboard && pnpm run build"
  },
  "keywords": [
    "ai-agent",
    "memory",
    "cognitive-architecture",
    "generative-agents",
    "solana",
    "supabase",
    "pgvector",
    "anthropic",
    "claude",
    "embeddings",
    "dream-cycle",
    "sdk",
    "persistent-memory",
    "agent-memory",
    "llm",
    "mcp",
    "long-term-memory",
    "memory-system",
    "vector-search",
    "knowledge-graph",
    "rag",
    "langchain",
    "ai-memory"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebbsssss/clude.git"
  },
  "homepage": "https://clude.io",
  "bugs": {
    "url": "https://github.com/sebbsssss/clude/issues"
  },
  "author": "sebbsssss",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.18.1",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.55",
    "@ai-sdk/openai": "^3.0.49",
    "@ai-sdk/xai": "^3.0.75",
    "@anthropic-ai/sdk": "^0.39.0",
    "@huggingface/transformers": "^4.1.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@privy-io/node": "^0.12.0",
    "@solana/web3.js": "^1.98.4",
    "@supabase/supabase-js": "^2.95.3",
    "ai": "^6.0.142",
    "better-sqlite3": "^12.9.0",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "jose": "^6.1.3",
    "multer": "^2.1.1",
    "murmurhash3js": "^3.0.1",
    "node-cron": "^3.0.3",
    "pino": "^9.0.0",
    "sqlite-vec": "^0.1.9",
    "tweetnacl": "^1.0.3",
    "twitter-api-v2": "^1.29.0",
    "unpdf": "^1.4.0",
    "vercel-minimax-ai-provider": "^0.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.11",
    "@types/node-cron": "^3.0.11",
    "esbuild": "^0.28.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "turbo": "^2.8.21",
    "typescript": "^5.6.0"
  },
  "optionalDependencies": {
    "utf-8-validate": "^5.0.10"
  }
}
