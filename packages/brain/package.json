{
  "name": "@clude/brain",
  "version": "2.7.8",
  "private": true,
  "description": "Clude brain — memory, dreams, agents, personality, SDK",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    },
    "./memory": {
      "types": "./dist/memory/index.d.ts",
      "default": "./dist/memory/index.js"
    },
    "./agents": {
      "types": "./dist/agents/index.d.ts",
      "default": "./dist/agents/index.js"
    },
    "./features/compound": {
      "types": "./dist/features/compound/index.d.ts",
      "default": "./dist/features/compound/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "default": "./dist/sdk/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.55",
    "@ai-sdk/openai": "^3.0.49",
    "@ai-sdk/xai": "^3.0.75",
    "@anthropic-ai/sdk": "^0.39.0",
    "@clude/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@privy-io/node": "^0.12.0",
    "@solana/web3.js": "^1.98.4",
    "@supabase/supabase-js": "^2.95.3",
    "ai": "^6.0.142",
    "better-sqlite3": "^12.9.0",
    "bs58": "^6.0.0",
    "express": "^4.21.0",
    "jose": "^6.1.3",
    "node-cron": "^3.0.3",
    "twitter-api-v2": "^1.29.0",
    "unpdf": "^1.4.0",
    "vercel-minimax-ai-provider": "^0.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.11",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  }
}
