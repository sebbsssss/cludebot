{
  "name": "@clude/shared",
  "version": "2.7.8",
  "private": true,
  "description": "Clude shared infrastructure — config, database, auth clients, utilities",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@privy-io/node": "^0.12.0",
    "@solana/web3.js": "^1.98.4",
    "@supabase/supabase-js": "^2.95.3",
    "bs58": "^6.0.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "jose": "^6.1.3",
    "multer": "^2.1.1",
    "pino": "^9.0.0",
    "tweetnacl": "^1.0.3",
    "twitter-api-v2": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.11",
    "typescript": "^5.6.0"
  }
}
