{
  "name": "@clude/workers",
  "version": "3.0.1",
  "private": true,
  "description": "Clude background jobs — scheduling, polling, dream cycles",
  "main": "dist/jobs/index.js",
  "exports": {
    ".": {
      "types": "./dist/jobs/index.d.ts",
      "default": "./dist/jobs/index.js"
    },
    "./*": {
      "types": "./dist/jobs/*.d.ts",
      "default": "./dist/jobs/*.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clude/shared": "workspace:*",
    "@clude/brain": "workspace:*",
    "twitter-api-v2": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
