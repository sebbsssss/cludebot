{
  "name": "@clude/server",
  "version": "2.7.8",
  "private": true,
  "description": "Clude HTTP server — serves API routes + static files",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clude/shared": "workspace:*",
    "@clude/brain": "workspace:*",
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.55",
    "@ai-sdk/openai": "^3.0.49",
    "@ai-sdk/xai": "^3.0.75",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@privy-io/node": "^0.12.0",
    "@solana/web3.js": "^1.98.4",
    "ai": "^6.0.142",
    "compression": "^1.8.1",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "multer": "^2.1.1",
    "unpdf": "^1.4.0",
    "bs58": "^6.0.0",
    "tweetnacl": "^1.0.3",
    "vercel-minimax-ai-provider": "^0.0.2"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.25",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.11",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  }
}
