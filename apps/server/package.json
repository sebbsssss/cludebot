{
  "name": "@clude/server",
  "version": "2.7.8",
  "private": true,
  "description": "Clude Bot backend server — memory SDK, API, MCP, and CLI",
  "main": "dist/index.js",
  "types": "dist/sdk/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/sdk/index.js",
      "types": "./dist/sdk/index.d.ts"
    },
    "./local": {
      "require": "./dist/mcp/local-store.js",
      "types": "./dist/mcp/local-store.d.ts"
    },
    "./mcp": {
      "require": "./dist/mcp/server.js",
      "types": "./dist/mcp/server.d.ts"
    }
  },
  "bin": {
    "clude-bot": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:sdk": "tsc -p tsconfig.sdk.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "mcp": "MCP_MODE=1 tsx src/mcp/server.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/google": "^3.0.55",
    "@ai-sdk/openai": "^3.0.49",
    "@ai-sdk/xai": "^3.0.75",
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@privy-io/node": "^0.12.0",
    "@solana/web3.js": "^1.98.4",
    "@supabase/supabase-js": "^2.95.3",
    "ai": "^6.0.142",
    "bs58": "^6.0.0",
    "compression": "^1.8.1",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "jose": "^6.1.3",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "pino": "^9.0.0",
    "tweetnacl": "^1.0.3",
    "twitter-api-v2": "^1.29.0",
    "unpdf": "^1.4.0",
    "vercel-minimax-ai-provider": "^0.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.25",
    "@types/http-proxy-middleware": "^1.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.11",
    "@types/node-cron": "^3.0.11",
    "http-proxy-middleware": "^3.0.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  },
  "optionalDependencies": {
    "utf-8-validate": "^5.0.10"
  }
}
