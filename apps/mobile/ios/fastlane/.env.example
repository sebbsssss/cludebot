# Copy this to `.env` and fill in your credentials. `.env` is gitignored.
#
# Generate an app-specific password at https://appleid.apple.com
#   → Sign-In and Security → App-Specific Passwords → Generate
#
# Then paste the xxxx-xxxx-xxxx-xxxx value below.

FASTLANE_USER=kohjunqiang@gmail.com
FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Optional: customize the changelog shown to TestFlight testers for each upload.
# TESTFLIGHT_CHANGELOG=Internal build.
